# Build configuration for ceph-volsync-plugin
# Used by Makefile and passed as --build-arg to
# container builds. Override on the CLI:
#   make docker-build-mover GOLANG_VERSION=1.25.7

CEPH_BASE_IMAGE=quay.io/ceph/ceph:v20
CEPH_VERSION=tentacle
GOLANG_VERSION=1.25.8
RSYNC_VERSION=3.2.5
STUNNEL_VERSION=5.71
