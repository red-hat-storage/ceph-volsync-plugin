# Build configuration for ceph-volsync-plugin
# Used by Makefile and passed as --build-arg to
# container builds. Override on the CLI:
#   make docker-build-mover GOLANG_VERSION=1.25.7

CEPH_BASE_IMAGE=quay.io/ceph/ceph:v20
CEPH_VERSION=tentacle
GOLANG_VERSION=1.25.7
RSYNC_VERSION=3.2.5
STUNNEL_VERSION=5.71

# Protoc tooling versions (build/Containerfile.protoc).
# Match protoc-gen-go and protoc-gen-go-grpc to the versions
# recorded in the generated file headers.
PROTOC_VERSION=29.3
PROTOC_GEN_GO_VERSION=v1.36.11
PROTOC_GEN_GO_GRPC_VERSION=v1.6.1
